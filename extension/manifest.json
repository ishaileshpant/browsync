{
  "manifest_version": 3,
  "name": "browsync",
  "version": "0.1.0",
  "description": "Cross-browser bookmark, history & session sync for browsync",
  "permissions": [
    "bookmarks",
    "tabs",
    "history",
    "nativeMessaging",
    "storage"
  ],
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  }
}
